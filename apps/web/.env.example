# =================================================================
# BTG Trader — Environment variables
# Copy to `.env.local` for local development.
# Set the same vars in Vercel → Project Settings → Environment.
# =================================================================

# ---------- Supabase ----------
# From Supabase dashboard → Project Settings → API.
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — used by server actions for privileged DB writes.
# NEVER expose this to the browser. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- App-level encryption ----------
# 32-byte random key, base64-encoded. Used by AES-256-GCM to encrypt the
# Bybit API secret before it is stored in Supabase. NEVER expose this.
# If it is rotated, every existing stored secret becomes unreadable.
#
# Generate one with:
#   PowerShell: [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
#   Node:       node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BTG_ENCRYPTION_KEY=

# ---------- Bybit ----------
# No env vars required. The app hits:
#   demo -> api-demo.bybit.com (Bybit Demo Trading)
#   live -> api.bybit.com      (Bybit mainnet)
# User-provided API keys are stored encrypted per-user in Supabase.
