# =================================================================
# BTG Trader — Environment variables
# Copy to `.env.local` for local development.
# Set the same vars in Vercel → Project Settings → Environment.
# =================================================================

# ---------- Supabase ----------
# From Supabase dashboard → Project Settings → API.
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — used by server actions for privileged DB writes.
# NEVER expose this to the browser. Do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Bybit ----------
# No env vars required. Public market data uses fixed endpoints
# (api.bybit.com / stream.bybit.com). User-provided API keys are
# stored encrypted per-user in Supabase, not in env.
